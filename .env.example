# ─────────────────────────────────────────────
# Variáveis de ambiente — copie para .env
# cp .env.example .env
# ─────────────────────────────────────────────

# MongoDB (padrão: instância local via Docker Compose)
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB=etl_db

# PostgreSQL (padrão: instância local via Docker Compose)
POSTGRES_URI=postgresql://etl_user:etl_pass@postgres:5432/etl_db
